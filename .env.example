# ── Gemini AI (Script Generation) ───────────────────────
# Add multiple keys separated by commas to rotate when quota is hit
GEMINI_API_KEYS=your_gemini_key_here,optional_second_key_here

# ── ElevenLabs (Premium Voice - optional) ───────────────
# Add multiple keys separated by commas to rotate when quota is hit
# Free tier: 10,000 chars/month per key. With 2 keys = 20k/month
# Example: sk_abc123xyz,sk_def456uvw
ELEVENLABS_API_KEYS=your_elevenlabs_key_here,optional_second_key_here

# ── Pexels (Background Videos & Images) ─────────────────
PEXELS_API_KEY=your_pexels_key_here

# ── YouTube Upload ───────────────────────────────────────
# token.json is auto-written by GitHub Actions from the YOUTUBE_TOKEN_JSON secret
# Run auth.py once locally to generate it, then paste contents into the secret

# ── Instagram Graph API (RECOMMENDED - most reliable) ────
# How to get these:
# 1. Create a Meta App at https://developers.facebook.com/
# 2. Link your Instagram Business/Creator account
# 3. Use Graph API Explorer to get a User Access Token with:
#      instagram_basic, instagram_content_publish, pages_read_engagement
# 4. Exchange for a long-lived token (valid ~60 days)
IG_BUSINESS_ACCOUNT_ID=your_numeric_ig_business_account_id
IG_GRAPH_ACCESS_TOKEN=your_long_lived_access_token

# ── Instagram Instagrapi Fallback (optional, may fail on cloud IPs) ──
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# ── Amazon Affiliate (optional) ─────────────────────────
AMAZON_AFFILIATE_TAG=tech8ytees-20
